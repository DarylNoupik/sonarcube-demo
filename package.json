{
  "name": "demo-js",
  "version": "1.0.0",
  "description": "Démo SonarQube — étape 4 : rapport d'exécution des tests.",
  "main": "app.js",
  "scripts": {
    "test": "jest --coverage"
  },
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-sonar": "^0.2.16"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "app.js"
    ],
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-sonar",
        {
          "outputDirectory": ".",
          "outputName": "test-report.xml",
          "reportedFilePath": "relative"
        }
      ]
    ]
  }
}
